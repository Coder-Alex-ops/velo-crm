# Supabase Postgres connection (use the Transaction Pooler URL on port 6543)
# Find it in: Supabase Dashboard → Project Settings → Database → Connection string → Transaction
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Random secret of at least 32 characters used to encrypt the session cookie
# Generate with: openssl rand -base64 32
SESSION_SECRET=
